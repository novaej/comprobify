PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sri_invoicing
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# Encryption key for certificate passwords stored in the database (32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Email delivery
EMAIL_PROVIDER=mailgun
# Display name + address, e.g. "Facturación <no-reply@mg.yourdomain.com>"
EMAIL_FROM=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com

# Dev seeder — used only by `npm run seed:dev` (never read by the app at runtime)
DEV_ISSUER_RUC=
DEV_ISSUER_BUSINESS_NAME=
DEV_ISSUER_TRADE_NAME=
DEV_ISSUER_ADDRESS=
DEV_ISSUER_BRANCH_CODE=001
DEV_ISSUER_ISSUE_POINT=001
DEV_ISSUER_ENVIRONMENT=1
DEV_ISSUER_ACCOUNTING=NO
DEV_ISSUER_CERT_PATH=cert/token.p12
# Plaintext P12 password — encrypted before storing in the DB
CERT_PASSWORD=
