PORT=8080

# SRI configuration
RUC=
ENVIRONMENT=1
BRANCH_CODE=001
ISSUE_POINT_CODE=001

# Certificate path (password is stored encrypted in the database)
CERT_PATH=cert/token.p12

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sri_invoicing
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# Encryption key for sensitive data (32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
