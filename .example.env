PORT=8080

# App environment — controls SRI endpoint routing
# staging    → always uses SRI test endpoint regardless of per-issuer sandbox flag
# production → uses SRI production endpoint for issuers with sandbox=false
APP_ENV=staging

# Public base URL of this API — required; used in verification email links when no
# per-tenant verificationRedirectUrl is set (e.g. https://api.yourdomain.com)
APP_BASE_URL=https://api.yourdomain.com

# Public docs base URL — used as prefix for RFC 7807 error type URIs
# When unset, error type URIs fall back to relative paths (/problems/...)
DOCS_BASE_URL=https://novaej.github.io/comprobify

# Verification token TTL in hours (default: 24)
# VERIFICATION_TOKEN_TTL_HOURS=24

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=comprobify_local
DB_USER=comprobify_app
DB_PASSWORD=
DB_SSL=false

# Encryption key for certificate passwords stored in the database (32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# SRI SOAP endpoints (override defaults if needed)
# SRI_TEST_BASE_URL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws
# SRI_PROD_BASE_URL=https://cel.sri.gob.ec/comprobantes-electronicos-ws

# Email delivery
EMAIL_PROVIDER=mailgun
# Bare email address only (no display name here — it is set in code):
#   Invoice/document emails: "{Issuer Business Name} via Comprobify <EMAIL_FROM>"
#   All other transactional emails: "Comprobify <EMAIL_FROM>"
EMAIL_FROM=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
# From Mailgun dashboard → Sending → Webhooks → Webhook signing key
MAILGUN_WEBHOOK_SIGNING_KEY=

# Admin API — required, protects /admin/* endpoints
# Must be a 64-char hex string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# Rate Limiting — per-API-key request limits
# RATE_LIMIT_WINDOW_MS: Time window in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_MAX: Base request count for write endpoints (default: 60)
#   - Write endpoints (POST): 60 requests per window
#   - Read endpoints (GET): 300 requests per window
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60

# Sentry error monitoring — DSN from your Sentry project settings. Leave blank to disable.
SENTRY_DSN=

# Bank transfer instructions — returned in the subscription-creation response so a
# tenant knows where to send the SPI transfer for a paid plan. Display text, not a secret.
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_TYPE=
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_ACCOUNT_HOLDER=
BANK_TRANSFER_IDENTIFICATION=

# Operator inbox notified when a tenant uploads payment proof needing review.
# Leave blank to skip that notification email (tenant-facing emails are unaffected).
ADMIN_NOTIFICATION_EMAIL=

# Operator identity — substituted into docs/legal/*.md templates when publishing
# legal documents via POST /v1/admin/legal-documents. Tokens available:
#   {{operador.nombre}}, {{operador.ruc}}, {{operador.email}}, {{operador.domicilio}}
# OPERATOR_ADDRESS defaults to "Domicilio disponible previa solicitud razonable"
# if left blank — use the actual address if you want it visible in the documents.
OPERATOR_NAME=Jonathan Andrés Pillajo Coka
OPERATOR_RUC=1715824775001
OPERATOR_EMAIL=japc.93@outlook.com
OPERATOR_ADDRESS=Diego de Salazar E15-189 y Antonia Salinas, Quito, Ecuador
