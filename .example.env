PORT=8080

# Public docs base URL — used as prefix for RFC 7807 error type URIs
# When unset, error type URIs fall back to relative paths (/problems/...)
DOCS_BASE_URL=https://novaej.gitbook.io/comprobify-api-docs

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sri_invoicing
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# Encryption key for certificate passwords stored in the database (32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# SRI SOAP endpoints (override defaults if needed)
# SRI_TEST_BASE_URL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws
# SRI_PROD_BASE_URL=https://cel.sri.gob.ec/comprobantes-electronicos-ws

# Email delivery
EMAIL_PROVIDER=mailgun
# Bare email address only — display name is set dynamically per issuer:
# "{Issuer Business Name} via Comprobify <EMAIL_FROM>"
EMAIL_FROM=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
# From Mailgun dashboard → Sending → Webhooks → Webhook signing key
MAILGUN_WEBHOOK_SIGNING_KEY=

# Admin API — required, protects /admin/* endpoints
# Must be a 64-char hex string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=
